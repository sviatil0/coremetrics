# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4
# MacPorts Portfile for CoreMetrics.
#
# Submission target: macports/macports-ports under aqua/coremetrics or
# sysutils/coremetrics. Bump `version` and `checksums` on each release.
# TODO: when first submitting, the MacPorts review will require running
# `port lint --nitpick coremetrics` against this file and resolving every
# warning.

PortSystem          1.0

name                coremetrics
version             0.2.18
revision            0
categories          sysutils aqua
license             LGPL-2.1
maintainers         {gmail.com:soleksiienko1 @sviatil0} openmaintainer
platforms           darwin
supported_archs     arm64 x86_64

description         Cross-platform desktop system metrics monitor (CPU / RAM / GPU / processes)
long_description    CoreMetrics is a small C++23 system monitor built directly on raw SDL3 \
                    pixel surfaces. It shows live CPU, RAM, GPU, and per-process resource \
                    usage with an optional rolling sparklines view and an htop-style kill \
                    flow on the Processes tab. Three native metrics backends (Linux /proc, \
                    macOS Mach + IOKit, Windows PDH) are selected at compile time.

homepage            https://github.com/sviatil0/coremetrics

master_sites        https://github.com/sviatil0/coremetrics/archive/refs/tags/
distname            v${version}
worksrcdir          ${name}-${version}

checksums           rmd160  REPLACE_WITH_RMD160 \
                    sha256  REPLACE_WITH_SHA256 \
                    size    REPLACE_WITH_SIZE

depends_build       port:pkgconfig
depends_lib         port:libsdl3 \
                    port:libsdl3_ttf \
                    port:libsdl3_image

compiler.cxx_standard   2023

use_configure       no

build.cmd           make
build.target        bin/coremetrics
build.env           CXXFLAGS="-std=c++23 -Wall -O2 -I ./include -I${prefix}/include" \
                    LDFLAGS="-L${prefix}/lib -lSDL3 -lSDL3_ttf -lSDL3_image -framework IOKit -framework CoreFoundation"

destroot {
    xinstall -m 0755 ${worksrcpath}/bin/coremetrics ${destroot}${prefix}/bin/coremetrics
    xinstall -d ${destroot}${prefix}/share/coremetrics
    xinstall -m 0644 ${worksrcpath}/base.xml ${destroot}${prefix}/share/coremetrics/base.xml
    copy ${worksrcpath}/assets ${destroot}${prefix}/share/coremetrics/assets
    xinstall -d ${destroot}${prefix}/share/man/man1
    xinstall -m 0644 ${worksrcpath}/man/coremetrics.1 \
        ${destroot}${prefix}/share/man/man1/coremetrics.1
}

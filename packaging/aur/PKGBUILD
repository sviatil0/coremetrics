# Maintainer: Sviatoslav Oleksiienko <soleksiienko1@gmail.com>
pkgname=coremetrics
pkgver=0.1.1
pkgrel=1
pkgdesc="Cross-platform desktop system metrics monitor (CPU / RAM / GPU / processes)"
arch=('x86_64' 'aarch64')
url="https://github.com/sviatil0/coremetrics"
license=('LGPL2.1')
depends=('sdl3' 'sdl3_ttf' 'sdl3_image')
makedepends=('gcc' 'make' 'pkg-config')
source=("$pkgname-$pkgver.tar.gz::https://github.com/sviatil0/coremetrics/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    mkdir -p obj bin
    make CXXFLAGS="-std=c++23 -Wall -O2 -I ./include $(pkg-config --cflags sdl3 sdl3-ttf sdl3-image)" \
         LDFLAGS="$(pkg-config --libs sdl3 sdl3-ttf sdl3-image)" \
         bin/coremetrics
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -D -m 0755 bin/coremetrics "$pkgdir/usr/bin/coremetrics"
    install -D -m 0644 base.xml "$pkgdir/usr/share/coremetrics/base.xml"
    cp -r assets "$pkgdir/usr/share/coremetrics/assets"
    install -D -m 0644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -D -m 0644 CONTRIBUTING.md "$pkgdir/usr/share/doc/$pkgname/CONTRIBUTING.md"
    install -D -m 0644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}

# Maintainer: Sviatoslav Oleksiienko <soleksiienko1@gmail.com>
pkgname=coremetrics-bin
pkgver=0.2.16
pkgrel=1
pkgdesc='Cross-platform desktop system metrics monitor (CPU, RAM, GPU, processes)'
arch=('x86_64')
url='https://github.com/sviatil0/coremetrics'
license=('LGPL-2.1-only')
depends=('sdl3' 'sdl3_ttf' 'sdl3_image')
source=("https://github.com/sviatil0/coremetrics/releases/download/v${pkgver}/coremetrics-v${pkgver}-linux-x86_64.tar.gz")
sha256sums=('86fa4d7dc7ca18f96000188e891242097510cf3b5edd22e99d872beb16f8bb9e')

package() {
  install -Dm755 "coremetrics-v${pkgver}-linux-x86_64/coremetrics" "$pkgdir/usr/bin/coremetrics"
  install -Dm644 "coremetrics-v${pkgver}-linux-x86_64/base.xml" "$pkgdir/usr/share/coremetrics/base.xml"
  cp -r "coremetrics-v${pkgver}-linux-x86_64/assets" "$pkgdir/usr/share/coremetrics/"
}
